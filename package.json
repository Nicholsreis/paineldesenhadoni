{
  "name": "balcao-senhas",
  "version": "1.0.0",
  "description": "Sistema de Gerenciamento de Senhas — Setor BALCÃO",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build:dir": "electron-builder --win --x64 --dir"
  },
  "dependencies": {
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.balcao.senhas",
    "productName": "BALCÃO Senhas",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": ["pt_BR"]
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "assets/**"
    ]
  }
}
